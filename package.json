{
  "name": "baseborn-io",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server/index.js",
    "start:local": "npm run build && node server/index.js",
    "test:multiplayer": "node scripts/multiplayer-smoke.mjs",
    "test:load": "node scripts/multiplayer-load.mjs",
    "test:persistence": "node scripts/persistence-smoke.mjs",
    "test": "npm run typecheck && npm run test:multiplayer && npm run test:load && npm run test:persistence"
  },
  "dependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "playwright": "^1.61.1"
  }
}
